# 토스증권 Open API 자격증명 (실제 값은 .env에만 기재 ― git 제외)
# Secret은 발급 1회만 노출됩니다. 평문 메모·메신저 전송 금지 (제안서 Step 0-2)
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
# 계좌번호(선택). API 헤더에는 계좌번호가 아닌 accountSeq(계좌 목록 API로 자동 해석)가
# 사용됨. 복수 계좌 보유 시 특정 계좌를 지정하는 용도 ― 단일 계좌면 비워둬도 됨.
ACCOUNT_NO=

# 알림 (Phase 8에서 사용)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
